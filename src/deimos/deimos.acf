LINE148="STATE000; if !dsch_ser_direction CALL ReadPixelsEOnly(15)"
LINE149="STATE000; if dsch_ser_direction CALL ReadPixelsFOnly(15)"
LINE150="STATE000; RETURN TDCser_ReadoutLoopDumpBright"
