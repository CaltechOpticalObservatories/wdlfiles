LINE95="STATE000; CALL Wait1ms(integrate_illum_ms)"
LINE96="STATE000; CALL Wait1s(integrate_illum_s)"
LINE97="STATE000; if illum CALL CloseShutter"
LINE98="STATE000; CALL Wait1ms(integrate_ms)"
LINE99="STATE000; CALL Wait1s(integrate_s)"
LINE100="STATE000; RETURN Integrate"
LINE101=ReadoutKeep:
