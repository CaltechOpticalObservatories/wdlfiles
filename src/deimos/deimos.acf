LINE127="STATE000; CALL ForwardParallelSectionBNoCoincident(llel_bin)"
LINE128="STATE000; CALL linbinincr(1)"
LINE129="STATE000; RETURN FrameReadoutTDCllel_Innerloop"
LINE130=FrameReadoutTDCser:
