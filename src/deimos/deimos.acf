LINE169="STATE000; if dsch_ser_direction CALL DumpPixelsFOnly(21)"
LINE170="STATE000; if !dsch_ser_direction CALL SerialFBackwards(ser_bin)"
LINE171="STATE000; if dsch_ser_direction CALL SerialEBackwards(ser_bin)"
LINE172="STATE000; CALL serbinincr(1)"
LINE173="STATE000; RETURN TDCser_Innerloop"
